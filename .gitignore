# ============================================
# Chatbot Arquitect — .gitignore
# ============================================
# Politica: el proyecto publico incluye TODO lo que sirve como template,
# conocimiento, referencias y entrenamiento. Lo UNICO excluido son los
# datos reales de clientes (informacion sensible).

# Secretos — NUNCA en git
.env
.env.*
!.env.example

# Data de clientes — NUNCA en git (informacion sensible)
# Cada cliente tiene su propia carpeta local con sus docs, prompts, etc.
# Solo el template de estructura se sube al repo publico.
clients/*
!clients/.template/
!clients/.template/**
!clients/.gitkeep

# Claude Code
CLAUDE.local.md
.claude/settings.local.json

# Sistema
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node
node_modules/
dist/
.next/
build/
package-lock.json

# IDEs
.vscode/settings.json
.idea/
*.swp
*.swo
*~
