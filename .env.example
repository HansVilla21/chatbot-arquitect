# ============================================
# CHATBOT ARQUITECT — Variables de Entorno
# ============================================
# Copia este archivo a .env y llena los valores reales
# NUNCA subas .env a git

# Anthropic (Claude Code)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (para los chatbots en n8n)
OPENAI_API_KEY=sk-...

# Perplexity (busquedas en tiempo real)
PERPLEXITY_API_KEY=pplx-...

# Supabase (base de datos de los chatbots)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://...
EVOLUTION_API_KEY=...

# n8n
N8N_URL=https://...
N8N_API_KEY=...

# Discord (notificaciones)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
