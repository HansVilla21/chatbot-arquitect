      "id": "c3f8a1b2-test-4a00-8b00-000000000101",
      "name": "Conversation",
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "PLACEHOLDER",
          "name": "{{CLIENTE}} - Postgres"
        }
